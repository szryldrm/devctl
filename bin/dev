#!/usr/bin/env bash

# Make sure tool install locations are visible regardless of how the shell
# was started, so opencode / codex / claude are detected and launchable.
export PATH="$HOME/.opencode/bin:$HOME/.local/bin:/usr/local/bin:$PATH"

# Ensure a UTF-8 locale so tmux and the tools render Unicode correctly.
case "${LANG:-}" in
  *UTF-8|*utf8) ;;
  *) export LANG=en_US.UTF-8 ;;
esac

DEFAULT_PROJECT_DIR="$HOME/projects"
CONFIG_DIR="$HOME/.config/devctl"
CONFIG_FILE="$CONFIG_DIR/config"
COMMAND="${1:-start}"
PROJECT_DIR="${2:-$PWD}"

if [ "$PROJECT_DIR" = "$HOME" ]; then
  PROJECT_DIR="$DEFAULT_PROJECT_DIR"
fi

PROJECT_DIR="$(realpath "$PROJECT_DIR")"
PROJECT_NAME="$(basename "$PROJECT_DIR")"
PROJECT_HASH="$(echo "$PROJECT_DIR" | sha1sum | cut -c1-8)"
SESSION="dev-${PROJECT_NAME}-${PROJECT_HASH}"
DISPLAY_DIR="${PROJECT_DIR/#$HOME/~}"

mkdir -p "$CONFIG_DIR"

create_default_config() {
  if [ ! -f "$CONFIG_FILE" ]; then
    cat > "$CONFIG_FILE" <<'CONFIG_EOF'
shell:shell:on
opencode:opencode:on
claude:claude:on
codex:codex:on
CONFIG_EOF
  fi
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

attach_or_switch() {
  if [ -n "$TMUX" ]; then
    tmux switch-client -t "$SESSION"
  else
    tmux attach -t "$SESSION"
  fi
}

style_session() {
  # Window numbering starts at 1 (renumber even if windows were made at 0).
  tmux set-option -t "$SESSION" base-index 1 >/dev/null 2>&1 || true
  tmux set-window-option -t "$SESSION" pane-base-index 1 >/dev/null 2>&1 || true
  tmux set-option -t "$SESSION" renumber-windows on >/dev/null 2>&1 || true
  tmux move-window -r -t "$SESSION" >/dev/null 2>&1 || true

  # Status bar: accent project badge on the left; project folder, session
  # name and clock on the right.
  tmux set-option -t "$SESSION" status on >/dev/null 2>&1 || true
  tmux set-option -t "$SESSION" status-interval 5 >/dev/null 2>&1 || true
  tmux set-option -t "$SESSION" status-justify left >/dev/null 2>&1 || true
  tmux set-option -t "$SESSION" status-style "bg=colour236,fg=colour250" >/dev/null 2>&1 || true

  tmux set-option -t "$SESSION" status-left \
    "#[fg=colour236,bg=colour141,bold] ◆ ${PROJECT_NAME} #[fg=colour141,bg=colour236,nobold] " \
    >/dev/null 2>&1 || true
  tmux set-option -t "$SESSION" status-left-length 40 >/dev/null 2>&1 || true

  tmux set-option -t "$SESSION" status-right \
    "#[fg=colour117]${DISPLAY_DIR} #[fg=colour236,bg=colour244,bold] ${SESSION} #[fg=colour236,bg=colour117,bold] %H:%M " \
    >/dev/null 2>&1 || true
  tmux set-option -t "$SESSION" status-right-length 120 >/dev/null 2>&1 || true

  tmux set-option -t "$SESSION" window-status-separator "" >/dev/null 2>&1 || true

  # Apply the window-tab styling to every window in the session so it sticks
  # regardless of tmux's per-window option scoping.
  local win
  for win in $(tmux list-windows -t "$SESSION" -F "#{window_id}" 2>/dev/null); do
    tmux set-window-option -t "$win" window-status-separator "" >/dev/null 2>&1 || true
    tmux set-window-option -t "$win" window-status-format \
      "#[fg=colour244] #I #[fg=colour250]#W " >/dev/null 2>&1 || true
    tmux set-window-option -t "$win" window-status-current-format \
      "#[fg=colour236,bg=colour117,bold] #I #W " >/dev/null 2>&1 || true
  done
}

create_windows() {
  local first_window_created="false"

  tmux set-option -g base-index 1 >/dev/null 2>&1 || true
  tmux set-window-option -g pane-base-index 1 >/dev/null 2>&1 || true
  tmux set-option -g renumber-windows on >/dev/null 2>&1 || true

  while IFS=":" read -r window_name window_command enabled; do
    if [ -z "$window_name" ] || [ -z "$window_command" ] || [ -z "$enabled" ]; then
      continue
    fi

    if [ "$enabled" != "on" ]; then
      continue
    fi

    if [ "$window_command" != "shell" ] && ! command_exists "$window_command"; then
      continue
    fi

    if [ "$first_window_created" = "false" ]; then
      tmux new-session -d -s "$SESSION" -c "$PROJECT_DIR" -n "$window_name"
      first_window_created="true"

      if [ "$window_command" != "shell" ]; then
        tmux send-keys -t "$SESSION:$window_name" "$window_command" C-m
      fi

      continue
    fi

    tmux new-window -t "$SESSION" -c "$PROJECT_DIR" -n "$window_name"

    if [ "$window_command" != "shell" ]; then
      tmux send-keys -t "$SESSION:$window_name" "$window_command" C-m
    fi
  done < "$CONFIG_FILE"

  if [ "$first_window_created" = "false" ]; then
    tmux new-session -d -s "$SESSION" -c "$PROJECT_DIR" -n shell
  fi
}

start_dev() {
  create_default_config
  mkdir -p "$PROJECT_DIR"

  if tmux has-session -t "$SESSION" 2>/dev/null; then
    attach_or_switch
    exit 0
  fi

  create_windows
  style_session
  tmux select-window -t "$SESSION:1"
  attach_or_switch
}

stop_dev() {
  if tmux has-session -t "$SESSION" 2>/dev/null; then
    tmux kill-session -t "$SESSION"
    echo "stopped: $SESSION"
  else
    echo "not running: $SESSION"
  fi
}

kill_dev() {
  TARGET="$2"

  if [ -z "$TARGET" ]; then
    echo "Usage: dev kill <session-name>"
    exit 1
  fi

  if tmux has-session -t "$TARGET" 2>/dev/null; then
    tmux kill-session -t "$TARGET"
    echo "killed: $TARGET"
  else
    echo "not found: $TARGET"
  fi
}

status_dev() {
  if tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "running: $SESSION"
    echo "path: $PROJECT_DIR"
    tmux list-windows -t "$SESSION"
  else
    echo "not running: $SESSION"
    echo "path: $PROJECT_DIR"
  fi
}

list_dev() {
  tmux list-sessions 2>/dev/null | grep '^dev-' || echo "no dev sessions"
}

run_config_editor() {
  local self_dir editor
  self_dir="$(cd "$(dirname "$0")" && pwd)"

  for editor in \
    "$self_dir/dev-config" \
    "$self_dir/../lib/devctl/dev-config" \
    "/usr/local/lib/devctl/dev-config"; do
    if [ -f "$editor" ]; then
      DEVCTL_CONFIG_FILE="$CONFIG_FILE" python3 "$editor"
      return 0
    fi
  done

  echo "config editor not found"
  cat "$CONFIG_FILE"
}

case "$COMMAND" in
  start)
    start_dev
    ;;
  stop)
    stop_dev
    ;;
  kill)
    kill_dev "$@"
    ;;
  restart)
    stop_dev
    start_dev
    ;;
  status)
    status_dev
    ;;
  list)
    list_dev
    ;;
  config)
    run_config_editor
    ;;
  *)
    echo "Usage: dev [start|stop|restart|status|list|kill|config] [path|session-name]"
    exit 1
    ;;
esac
