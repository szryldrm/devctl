#!/usr/bin/env python3

import curses
import os
import sys
from pathlib import Path

config_file = Path(os.environ.get("DEVCTL_CONFIG_FILE", str(Path.home() / ".config/devctl/config")))

DEFAULT_CONFIG = "shell:shell:on\nopencode:opencode:on\nclaude:claude:on\ncodex:codex:on\n"

# ---------------------------------------------------------------------------
# Data
# ---------------------------------------------------------------------------

def load_items():
    config_file.parent.mkdir(parents=True, exist_ok=True)

    if not config_file.exists():
        config_file.write_text(DEFAULT_CONFIG)

    items = []

    for line in config_file.read_text().splitlines():
        parts = line.split(":", 2)

        if len(parts) == 3:
            items.append({"name": parts[0], "command": parts[1], "enabled": parts[2]})

    return items

def save_items(items):
    config_file.write_text("".join(f"{i['name']}:{i['command']}:{i['enabled']}\n" for i in items))

# ---------------------------------------------------------------------------
# Theme
# ---------------------------------------------------------------------------

PAIRS = {}

def setup_colors():
    curses.start_color()
    curses.use_default_colors()

    if curses.COLORS >= 256:
        accent, sky, green, amber, red = 141, 117, 114, 215, 203
        text, dim, bar, selbg, offbg, dark = 252, 244, 236, 237, 238, 236
    else:
        accent, sky, green = curses.COLOR_MAGENTA, curses.COLOR_CYAN, curses.COLOR_GREEN
        amber, red = curses.COLOR_YELLOW, curses.COLOR_RED
        text, dim, bar = curses.COLOR_WHITE, curses.COLOR_WHITE, curses.COLOR_BLUE
        selbg, offbg, dark = curses.COLOR_BLUE, curses.COLOR_BLACK, curses.COLOR_BLACK

    spec = {
        "accent":     (accent, -1),
        "text":       (text, -1),
        "muted":      (dim, -1),
        "cmd":        (sky, -1),
        "toast":      (green, -1),
        "warn":       (amber, -1),
        "danger":     (red, -1),
        "bar":        (dim, bar),
        "warnbar":    (amber, bar),
        "panel":      (text, bar),
        "panel_border": (accent, bar),
        "brand":      (dark, accent),
        "key":        (dark, accent),
        "keylabel":   (text, bar),
        "on":         (dark, green),
        "off":        (dim, offbg),
        "sel_text":   (text, selbg),
        "sel_muted":  (dim, selbg),
        "sel_accent": (accent, selbg),
        "sel_cmd":    (sky, selbg),
    }

    index = 1
    for name, (fg, bg) in spec.items():
        try:
            curses.init_pair(index, fg, bg)
        except curses.error:
            curses.init_pair(index, curses.COLOR_WHITE, -1)
        PAIRS[name] = index
        index += 1

def attr(name, bold=False):
    a = curses.color_pair(PAIRS.get(name, 0))
    if bold:
        a |= curses.A_BOLD
    return a

# ---------------------------------------------------------------------------
# Low-level drawing helpers (all clipped + crash-safe)
# ---------------------------------------------------------------------------

def put(stdscr, y, x, text, a=0):
    h, w = stdscr.getmaxyx()

    if y < 0 or y >= h:
        return

    if x < 0:
        text = text[-x:]
        x = 0

    if x >= w:
        return

    text = text[: w - x]

    try:
        stdscr.addstr(y, x, text, a)
    except curses.error:
        pass

def fill(stdscr, y, a):
    h, w = stdscr.getmaxyx()

    if y < 0 or y >= h:
        return

    try:
        stdscr.addstr(y, 0, " " * (w - 1), a)
        stdscr.insstr(y, w - 1, " ", a)
    except curses.error:
        pass

def truncate(value, length):
    if length <= 0:
        return ""
    if len(value) <= length:
        return value
    if length == 1:
        return "…"
    return value[: length - 1] + "…"

# ---------------------------------------------------------------------------
# Full layout
# ---------------------------------------------------------------------------

def draw_header(stdscr, width, count, dirty):
    fill(stdscr, 0, attr("bar"))
    fill(stdscr, 1, attr("bar"))

    put(stdscr, 0, 0, "  ", attr("bar"))
    put(stdscr, 0, 2, " ◆ devctl ", attr("brand", bold=True))
    put(stdscr, 0, 12, "  development session manager", attr("bar"))

    if dirty:
        badge = " ● unsaved "
        put(stdscr, 0, width - len(badge) - 1, badge, attr("warnbar", bold=True))
    else:
        badge = f"{count} window{'s' if count != 1 else ''} "
        put(stdscr, 0, width - len(badge) - 1, badge, attr("bar"))

    path = truncate(str(config_file), width - 4)
    put(stdscr, 1, 2, path, attr("bar"))

def draw_table(stdscr, items, selected, top, height, width):
    left = 2
    no_w = 3
    status_w = 7

    name_w = max(10, min(20, max((len(i["name"]) for i in items), default=8) + 2))
    gap = 2
    command_w = max(12, width - left - no_w - name_w - status_w - (gap * 4) - 2)

    header_y = top
    cols = (
        " " * no_w
        + " " * gap
        + f"{'WINDOW':<{name_w}}"
        + " " * gap
        + f"{'COMMAND':<{command_w}}"
        + " " * gap
        + "STATUS"
    )
    put(stdscr, header_y, left, truncate(cols, width - left - 1), attr("muted", bold=True))
    put(stdscr, header_y + 1, left, "─" * min(width - left - 2, len(cols) + 2), attr("muted"))

    rows_top = header_y + 2
    visible = max(1, height - rows_top - 4)

    offset = 0
    if selected >= visible:
        offset = selected - visible + 1

    for vi, item in enumerate(items[offset : offset + visible]):
        idx = offset + vi
        y = rows_top + vi
        is_sel = idx == selected
        enabled = item["enabled"] == "on"

        if is_sel:
            fill(stdscr, y, attr("sel_text"))
            put(stdscr, y, 0, " ▎", attr("sel_accent", bold=True))
            num_a = attr("sel_muted")
            name_a = attr("sel_text", bold=True)
            cmd_a = attr("sel_cmd")
        else:
            num_a = attr("muted")
            name_a = attr("text", bold=enabled)
            cmd_a = attr("cmd") if enabled else attr("muted")

        x = left
        put(stdscr, y, x, f"{idx + 1:>{no_w}}", num_a)
        x += no_w + gap
        put(stdscr, y, x, f"{truncate(item['name'], name_w):<{name_w}}", name_a)
        x += name_w + gap
        put(stdscr, y, x, f"{truncate(item['command'], command_w):<{command_w}}", cmd_a)
        x += command_w + gap

        if enabled:
            put(stdscr, y, x, " ON ", attr("on", bold=True))
        else:
            put(stdscr, y, x, " OFF ", attr("off"))

    return rows_top, visible, offset

def draw_footer(stdscr, height, width, message):
    msg_y = height - 3
    if message:
        icon, pair = message
        put(stdscr, msg_y, 2, truncate(f"{icon}", width - 4), attr(pair, bold=True))

    bar_y = height - 1
    fill(stdscr, bar_y, attr("keylabel"))

    hints = [
        ("↑↓", "select"),
        ("space", "toggle"),
        ("⏎", "edit"),
        ("a", "add"),
        ("d", "delete"),
        ("J/K", "reorder"),
        ("q", "quit"),
    ]

    x = 1
    for key, label in hints:
        key_txt = f" {key} "
        lbl_txt = f" {label}  "
        if x + len(key_txt) + len(lbl_txt) >= width:
            break
        put(stdscr, bar_y, x, key_txt, attr("key", bold=True))
        x += len(key_txt)
        put(stdscr, bar_y, x, lbl_txt, attr("keylabel"))
        x += len(lbl_txt)

def draw(stdscr, items, selected, message, dirty):
    stdscr.erase()
    height, width = stdscr.getmaxyx()

    draw_header(stdscr, width, len(items), dirty)

    if items:
        draw_table(stdscr, items, selected, 3, height, width)
    else:
        put(stdscr, 5, 4, "No windows configured.", attr("muted"))
        put(stdscr, 6, 4, "Press 'a' to add one.", attr("muted"))

    draw_footer(stdscr, height, width, message)
    stdscr.noutrefresh()
    curses.doupdate()

# ---------------------------------------------------------------------------
# Compact layout (narrow / short terminals)
# ---------------------------------------------------------------------------

def draw_small(stdscr, items, selected, message, dirty):
    stdscr.erase()
    height, width = stdscr.getmaxyx()

    fill(stdscr, 0, attr("bar"))
    put(stdscr, 0, 1, " ◆ devctl ", attr("brand", bold=True))
    if dirty:
        tag = " ● unsaved "
        put(stdscr, 0, width - len(tag) - 1, tag, attr("warnbar", bold=True))

    top = 2
    visible = max(1, height - top - 2)
    offset = 0
    if selected >= visible:
        offset = selected - visible + 1

    for vi, item in enumerate(items[offset : offset + visible]):
        idx = offset + vi
        y = top + vi
        enabled = item["enabled"] == "on"
        marker = "●" if enabled else "○"
        is_sel = idx == selected

        if is_sel:
            fill(stdscr, y, attr("sel_text"))
            put(stdscr, y, 0, " ▎", attr("sel_accent", bold=True))
            text_a = attr("sel_text", bold=True)
            mark_a = attr("sel_accent", bold=True)
        else:
            text_a = attr("text", bold=enabled)
            mark_a = attr("toast", bold=True) if enabled else attr("muted")

        put(stdscr, y, 2, marker, mark_a)
        put(stdscr, y, 4, truncate(item["name"], width - 6), text_a)

    if message:
        icon, pair = message
        put(stdscr, height - 2, 1, truncate(icon, width - 2), attr(pair, bold=True))

    fill(stdscr, height - 1, attr("keylabel"))
    put(stdscr, height - 1, 1, " space ", attr("key", bold=True))
    put(stdscr, height - 1, 8, "toggle  ", attr("keylabel"))
    put(stdscr, height - 1, 16, " e ", attr("key", bold=True))
    put(stdscr, height - 1, 19, "edit  ", attr("keylabel"))
    put(stdscr, height - 1, 25, " q ", attr("key", bold=True))
    put(stdscr, height - 1, 28, "quit", attr("keylabel"))

    stdscr.noutrefresh()
    curses.doupdate()

def render(stdscr, items, selected, message, dirty):
    height, width = stdscr.getmaxyx()

    if width < 56 or height < 14:
        draw_small(stdscr, items, selected, message, dirty)
    else:
        draw(stdscr, items, selected, message, dirty)

# ---------------------------------------------------------------------------
# Input prompts
# ---------------------------------------------------------------------------

def prompt(stdscr, label, default=""):
    height, width = stdscr.getmaxyx()
    y = height - 1

    fill(stdscr, y, attr("keylabel"))
    tag = f" {label} "
    put(stdscr, y, 1, tag, attr("key", bold=True))
    put(stdscr, y, 1 + len(tag), " ", attr("keylabel"))

    curses.curs_set(1)
    curses.echo()

    field_x = 1 + len(tag) + 1
    put(stdscr, y, field_x, default, attr("text"))
    stdscr.move(y, min(width - 2, field_x + len(default)))
    stdscr.refresh()

    try:
        value = stdscr.getstr(y, field_x, 120).decode("utf-8").strip()
    except Exception:
        value = ""

    curses.noecho()
    curses.curs_set(0)

    return value if value else default

def edit_item(stdscr, item):
    name = prompt(stdscr, "name", item["name"])
    if name:
        item["name"] = name

    command = prompt(stdscr, "command", item["command"])
    if command:
        item["command"] = command

def add_item(stdscr, items):
    name = prompt(stdscr, "new name", "")
    if not name:
        return None

    command = prompt(stdscr, "command", name)
    if not command:
        return None

    items.append({"name": name, "command": command, "enabled": "on"})
    return name

def confirm_exit(stdscr):
    h, w = stdscr.getmaxyx()
    bw = min(52, max(38, w - 6))
    bh = 7
    by = max(0, (h - bh) // 2)
    bx = max(0, (w - bw) // 2)

    panel = attr("panel")
    border = attr("panel_border", bold=True)

    for r in range(bh):
        put(stdscr, by + r, bx, " " * bw, panel)

    put(stdscr, by, bx, "╭" + "─" * (bw - 2) + "╮", border)
    put(stdscr, by + bh - 1, bx, "╰" + "─" * (bw - 2) + "╯", border)
    for r in range(1, bh - 1):
        put(stdscr, by + r, bx, "│", border)
        put(stdscr, by + r, bx + bw - 1, "│", border)

    title = "Save changes before exiting?"
    put(stdscr, by + 2, bx + (bw - len(title)) // 2, title, attr("panel", bold=True))

    y_lbl, n_lbl, c_lbl = " y save ", " n discard ", " c cancel "
    total = len(y_lbl) + len(n_lbl) + len(c_lbl) + 4
    ox = bx + (bw - total) // 2
    put(stdscr, by + 4, ox, y_lbl, attr("on", bold=True))
    put(stdscr, by + 4, ox + len(y_lbl) + 2, n_lbl, attr("off", bold=True))
    put(stdscr, by + 4, ox + len(y_lbl) + len(n_lbl) + 4, c_lbl, attr("key", bold=True))

    stdscr.noutrefresh()
    curses.doupdate()

    while True:
        k = stdscr.getch()
        if k in (ord("y"), ord("Y")):
            return "save"
        if k in (ord("n"), ord("N")):
            return "discard"
        if k in (ord("c"), ord("C"), 27):
            return "cancel"

# ---------------------------------------------------------------------------
# Main loop
# ---------------------------------------------------------------------------

def snapshot_of(items):
    return [(i["name"], i["command"], i["enabled"]) for i in items]

def main(stdscr):
    curses.curs_set(0)
    setup_colors()
    stdscr.keypad(True)

    items = load_items()
    saved = snapshot_of(items)
    selected = 0
    message = ("↕ select · space toggle · changes saved on exit", "muted")

    while True:
        if items and selected >= len(items):
            selected = len(items) - 1
        if selected < 0:
            selected = 0

        dirty = snapshot_of(items) != saved
        render(stdscr, items, selected, message, dirty)
        key = stdscr.getch()
        message = None

        if key in (27, ord("q")):
            if snapshot_of(items) == saved:
                break
            choice = confirm_exit(stdscr)
            if choice == "save":
                save_items(items)
                break
            if choice == "discard":
                break
            # cancel: stay in the editor
            message = ("changes not saved yet", "warn")
            continue

        if key in (curses.KEY_UP, ord("k")):
            selected = max(0, selected - 1)
            continue

        if key in (curses.KEY_DOWN, ord("j")):
            selected = min(len(items) - 1, selected + 1)
            continue

        if not items:
            if key == ord("a"):
                curses.curs_set(1)
                name = add_item(stdscr, items)
                curses.curs_set(0)
                selected = len(items) - 1
                message = (f"✓ added {name}", "toast") if name else ("add cancelled", "warn")
            continue

        if key in (ord(" "), 9):  # space or Tab
            items[selected]["enabled"] = "off" if items[selected]["enabled"] == "on" else "on"
            state = items[selected]["enabled"].upper()
            message = (f"{items[selected]['name']} → {state}", "toast")
            continue

        if key in (10, 13, curses.KEY_ENTER, ord("e")):
            edit_item(stdscr, items[selected])
            message = (f"edited {items[selected]['name']}", "toast")
            continue

        if key == ord("a"):
            name = add_item(stdscr, items)
            selected = len(items) - 1
            message = (f"added {name}", "toast") if name else ("add cancelled", "warn")
            continue

        if key == ord("d"):
            removed = items.pop(selected)
            message = (f"deleted {removed['name']}", "danger")
            continue

        # Reorder: Shift+Up/Down or uppercase K/J move the selected item.
        if key in (curses.KEY_SR, ord("K")) and selected > 0:
            items[selected - 1], items[selected] = items[selected], items[selected - 1]
            selected -= 1
            message = ("moved up", "toast")
            continue

        if key in (curses.KEY_SF, ord("J")) and selected < len(items) - 1:
            items[selected + 1], items[selected] = items[selected], items[selected + 1]
            selected += 1
            message = ("moved down", "toast")
            continue

if __name__ == "__main__":
    try:
        curses.wrapper(main)
    except KeyboardInterrupt:
        sys.exit(0)
