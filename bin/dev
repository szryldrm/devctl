#!/usr/bin/env bash

# Make sure tool install locations are visible regardless of how the shell
# was started, so opencode / codex / claude are detected and launchable.
export PATH="$HOME/.opencode/bin:$HOME/.local/bin:/usr/local/bin:$PATH"

# Ensure a UTF-8 locale so tmux and the tools render Unicode correctly.
# Only switch to a locale that actually exists, to avoid setlocale warnings.
case "${LANG:-}" in
  *[Uu][Tt][Ff]*8*) ;;
  *)
    for _loc in C.UTF-8 C.utf8 en_US.UTF-8 en_US.utf8; do
      if locale -a 2>/dev/null | grep -qix "$_loc"; then
        export LANG="$_loc"
        break
      fi
    done
    unset _loc
    ;;
esac

DEFAULT_PROJECT_DIR="$HOME/projects"
CONFIG_DIR="$HOME/.config/devctl"
CONFIG_FILE="$CONFIG_DIR/config.json"
COMMAND="${1:-start}"
PROJECT_DIR="${2:-$PWD}"

if [ "$PROJECT_DIR" = "$HOME" ]; then
  PROJECT_DIR="$DEFAULT_PROJECT_DIR"
fi

PROJECT_DIR="$(realpath "$PROJECT_DIR")"
PROJECT_NAME="$(basename "$PROJECT_DIR")"
PROJECT_HASH="$(echo "$PROJECT_DIR" | sha1sum | cut -c1-8)"
SESSION="dev-${PROJECT_NAME}-${PROJECT_HASH}"
DISPLAY_DIR="${PROJECT_DIR/#$HOME/~}"

mkdir -p "$CONFIG_DIR"

create_default_config() {
  [ -f "$CONFIG_FILE" ] && return 0

  # Create config.json on first run: migrate a legacy colon "config" file if
  # present, otherwise default to shell plus whichever tools are installed.
  python3 - "$CONFIG_FILE" <<'PY'
import json, os, sys, shutil

path = sys.argv[1]
legacy = os.path.join(os.path.dirname(path), "config")

if os.path.exists(legacy):
    wins = []
    for line in open(legacy):
        parts = line.strip().split(":", 2)
        if len(parts) == 3:
            wins.append({"name": parts[0], "command": parts[1], "enabled": parts[2] == "on"})
else:
    wins = [{"name": "shell", "command": "shell", "enabled": True}]
    for t in ("opencode", "claude", "codex"):
        if shutil.which(t):
            wins.append({"name": t, "command": t, "enabled": True})

with open(path, "w") as f:
    json.dump({"windows": wins}, f, indent=2)
    f.write("\n")
PY
}

read_windows() {
  # Emit "name<TAB>command" for each enabled window.
  python3 - "$CONFIG_FILE" <<'PY'
import json, sys
try:
    wins = json.load(open(sys.argv[1])).get("windows", [])
except Exception:
    wins = []
for w in wins:
    if w.get("enabled"):
        print(f"{w.get('name','')}\t{w.get('command','')}")
PY
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

attach_or_switch() {
  # Resume the session if it was frozen (no-op otherwise) before attaching.
  signal_session CONT "$SESSION"

  if [ -n "$TMUX" ]; then
    tmux switch-client -t "$SESSION"
  else
    tmux attach -t "$SESSION"
  fi
}

style_session() {
  # Window numbering starts at 1 (renumber even if windows were made at 0).
  tmux set-option -t "$SESSION" base-index 1 >/dev/null 2>&1 || true
  tmux set-window-option -t "$SESSION" pane-base-index 1 >/dev/null 2>&1 || true
  tmux set-option -t "$SESSION" renumber-windows on >/dev/null 2>&1 || true
  tmux move-window -r -t "$SESSION" >/dev/null 2>&1 || true

  # Status bar: accent project badge on the left; project folder, session
  # name and clock on the right.
  tmux set-option -t "$SESSION" status on >/dev/null 2>&1 || true
  tmux set-option -t "$SESSION" status-interval 5 >/dev/null 2>&1 || true
  tmux set-option -t "$SESSION" status-justify left >/dev/null 2>&1 || true
  tmux set-option -t "$SESSION" status-style "bg=colour236,fg=colour250" >/dev/null 2>&1 || true

  tmux set-option -t "$SESSION" status-left \
    "#[fg=colour236,bg=colour141,bold] ◆ ${PROJECT_NAME} #[fg=colour141,bg=colour236,nobold] " \
    >/dev/null 2>&1 || true
  tmux set-option -t "$SESSION" status-left-length 40 >/dev/null 2>&1 || true

  tmux set-option -t "$SESSION" status-right \
    "#[fg=colour117]${DISPLAY_DIR} #[fg=colour236,bg=colour244,bold] ${SESSION} #[fg=colour236,bg=colour117,bold] %H:%M " \
    >/dev/null 2>&1 || true
  tmux set-option -t "$SESSION" status-right-length 120 >/dev/null 2>&1 || true

  tmux set-option -t "$SESSION" window-status-separator "" >/dev/null 2>&1 || true

  # Apply the window-tab styling to every window in the session so it sticks
  # regardless of tmux's per-window option scoping.
  local win
  for win in $(tmux list-windows -t "$SESSION" -F "#{window_id}" 2>/dev/null); do
    tmux set-window-option -t "$win" window-status-separator "" >/dev/null 2>&1 || true
    tmux set-window-option -t "$win" window-status-format \
      "#[fg=colour244] #I #[fg=colour250]#W " >/dev/null 2>&1 || true
    tmux set-window-option -t "$win" window-status-current-format \
      "#[fg=colour236,bg=colour117,bold] #I #W " >/dev/null 2>&1 || true
  done

  # Ctrl+B then Ctrl+F = freeze + detach (intentional); reattach auto-thaws.
  # C-f avoids clashing with the default prefix 'f' (find-window).
  # Normal Ctrl+B D and dropped connections keep the session running.
  local dev_bin
  dev_bin="$(command -v dev 2>/dev/null)"
  [ -z "$dev_bin" ] && dev_bin="$(cd "$(dirname "$0")" && pwd)/dev"

  tmux bind-key C-f run-shell -b "$dev_bin freeze-detach #{session_name}" >/dev/null 2>&1 || true
  tmux set-hook -t "$SESSION" client-attached \
    "run-shell -b '$dev_bin thaw #{session_name}'" >/dev/null 2>&1 || true
}

create_windows() {
  local first_window_created="false"

  # Window numbering / renumbering is configured per-session in style_session
  # (which also runs move-window -r), so it is not set globally here.
  while IFS=$'\t' read -r window_name window_command; do
    if [ -z "$window_name" ] || [ -z "$window_command" ]; then
      continue
    fi

    if [ "$window_command" != "shell" ] && ! command_exists "$window_command"; then
      continue
    fi

    if [ "$first_window_created" = "false" ]; then
      tmux new-session -d -s "$SESSION" -c "$PROJECT_DIR" -n "$window_name"
      first_window_created="true"

      if [ "$window_command" != "shell" ]; then
        tmux send-keys -t "$SESSION:$window_name" "$window_command" C-m
      fi

      continue
    fi

    tmux new-window -t "$SESSION" -c "$PROJECT_DIR" -n "$window_name"

    if [ "$window_command" != "shell" ]; then
      tmux send-keys -t "$SESSION:$window_name" "$window_command" C-m
    fi
  done < <(read_windows)

  if [ "$first_window_created" = "false" ]; then
    tmux new-session -d -s "$SESSION" -c "$PROJECT_DIR" -n shell
  fi
}

start_dev() {
  create_default_config
  mkdir -p "$PROJECT_DIR"

  if tmux has-session -t "$SESSION" 2>/dev/null; then
    attach_or_switch
    exit 0
  fi

  create_windows
  style_session
  tmux select-window -t "$SESSION:1"
  attach_or_switch
}

stop_dev() {
  if tmux has-session -t "$SESSION" 2>/dev/null; then
    tmux kill-session -t "$SESSION"
    echo "stopped: $SESSION"
  else
    echo "not running: $SESSION"
  fi
}

# Resolve a session from an exact name or a unique fragment (e.g. the hash).
# Prints the resolved name on success; prints candidates to stderr if ambiguous.
# Returns 0 ok, 1 not found, 2 ambiguous.
resolve_session() {
  local frag="$1"

  if tmux has-session -t "$frag" 2>/dev/null; then
    echo "$frag"
    return 0
  fi

  local matches count
  matches="$(tmux list-sessions -F "#{session_name}" 2>/dev/null | grep '^dev-' | grep -F "$frag")"
  count="$(printf '%s' "$matches" | grep -c .)"

  if [ "$count" -eq 1 ]; then
    echo "$matches"
    return 0
  elif [ "$count" -eq 0 ]; then
    return 1
  else
    { echo "multiple sessions match '$frag':"; printf '  %s\n' $matches; } >&2
    return 2
  fi
}

kill_dev() {
  local target="$2" session rc

  if [ -z "$target" ]; then
    echo "Usage: dev kill <session-name | fragment>"
    exit 1
  fi

  session="$(resolve_session "$target")"; rc=$?
  if [ $rc -ne 0 ]; then
    [ $rc -eq 1 ] && echo "not found: $target"
    exit 1
  fi

  tmux kill-session -t "$session"
  echo "killed: $session"
}

current_attached_session() {
  [ -n "$TMUX" ] && tmux display-message -p '#{session_name}' 2>/dev/null
}

# Recursively echo all descendant PIDs of a PID.
descendants() {
  local pid="$1" child
  for child in $(pgrep -P "$pid" 2>/dev/null); do
    descendants "$child"
    printf '%s ' "$child"
  done
}

# Send STOP or CONT to every process in a session's panes (and their children).
signal_session() {
  local sig="$1" session="$2" pid kids
  for pid in $(tmux list-panes -s -t "$session" -F "#{pane_pid}" 2>/dev/null); do
    kids="$(descendants "$pid")"
    if [ "$sig" = "STOP" ]; then
      kill -STOP $kids "$pid" 2>/dev/null || true
    else
      kill -CONT "$pid" $kids 2>/dev/null || true
    fi
  done
}

is_frozen() {
  local pid
  pid="$(tmux list-panes -s -t "$1" -F "#{pane_pid}" 2>/dev/null | head -1)"
  [ -n "$pid" ] || return 1
  case "$(ps -o state= -p "$pid" 2>/dev/null)" in
    T*) return 0 ;;
    *) return 1 ;;
  esac
}

# freeze (STOP) / thaw (CONT) a session — default current, a fragment, or "all".
freeze_dev() {
  local verb="$1" target="$2" sig label
  if [ "$verb" = "freeze" ]; then sig="STOP"; label="frozen"; else sig="CONT"; label="thawed"; fi

  local current; current="$(current_attached_session)"

  if [ "$target" = "all" ]; then
    local session
    for session in $(tmux list-sessions -F "#{session_name}" 2>/dev/null | grep '^dev-'); do
      if [ "$sig" = "STOP" ] && [ "$session" = "$current" ]; then
        echo "skipped (attached): $session"
        continue
      fi
      signal_session "$sig" "$session"
      echo "$label: $session"
    done
    return 0
  fi

  local session rc
  session="$(resolve_session "${target:-$SESSION}")"; rc=$?
  if [ $rc -ne 0 ]; then
    [ $rc -eq 1 ] && echo "not found: ${target:-$SESSION}"
    exit 1
  fi

  if [ "$sig" = "STOP" ] && [ "$session" = "$current" ]; then
    echo "refusing to freeze the session you are attached to: $session"
    echo "detach first (Ctrl+B then D), then: dev freeze $session"
    exit 1
  fi

  signal_session "$sig" "$session"
  echo "$label: $session"
}

# Detach all clients from a session, then freeze it. Used by the Ctrl+B F
# binding so the freeze never hits the "attached" guard.
freeze_detach() {
  local session="$2"
  [ -z "$session" ] && session="$SESSION"

  tmux detach-client -s "$session" 2>/dev/null || true
  signal_session STOP "$session"
}

status_dev() {
  if tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "running: $SESSION"
    echo "path: $PROJECT_DIR"
    tmux list-windows -t "$SESSION"
  else
    echo "not running: $SESSION"
    echo "path: $PROJECT_DIR"
  fi
}

list_dev() {
  local any=0 line session
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    any=1
    session="${line%%:*}"
    if is_frozen "$session"; then
      echo "$line  (frozen)"
    else
      echo "$line"
    fi
  done < <(tmux list-sessions 2>/dev/null | grep '^dev-')

  [ "$any" -eq 0 ] && echo "no dev sessions"
}

run_config_editor() {
  local self_dir editor
  self_dir="$(cd "$(dirname "$0")" && pwd)"

  for editor in \
    "$self_dir/dev-config" \
    "$self_dir/../lib/devctl/dev-config" \
    "/usr/local/lib/devctl/dev-config"; do
    if [ -f "$editor" ]; then
      DEVCTL_CONFIG_FILE="$CONFIG_FILE" python3 "$editor"
      return 0
    fi
  done

  echo "config editor not found"
  cat "$CONFIG_FILE"
}

case "$COMMAND" in
  start)
    start_dev
    ;;
  stop)
    stop_dev
    ;;
  kill)
    kill_dev "$@"
    ;;
  restart)
    stop_dev
    start_dev
    ;;
  status)
    status_dev
    ;;
  list)
    list_dev
    ;;
  config)
    run_config_editor
    ;;
  freeze)
    freeze_dev freeze "$2"
    ;;
  thaw)
    freeze_dev thaw "$2"
    ;;
  freeze-detach)
    freeze_detach "$@"
    ;;
  *)
    echo "Usage: dev [start|stop|restart|status|list|config] [path]"
    echo "       dev kill <session|fragment>"
    echo "       dev freeze [session|fragment|all]   pause a session (SIGSTOP)"
    echo "       dev thaw   [session|fragment|all]   resume a session (SIGCONT)"
    echo "       (in tmux: Ctrl+B then Ctrl+F = freeze + detach; reattach resumes)"
    exit 1
    ;;
esac
