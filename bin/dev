#!/usr/bin/env bash

DEFAULT_PROJECT_DIR="$HOME/projects"
CONFIG_DIR="$HOME/.config/devctl"
CONFIG_FILE="$CONFIG_DIR/config"
COMMAND="${1:-start}"
PROJECT_DIR="${2:-$PWD}"

if [ "$PROJECT_DIR" = "$HOME" ]; then
  PROJECT_DIR="$DEFAULT_PROJECT_DIR"
fi

PROJECT_DIR="$(realpath "$PROJECT_DIR")"
PROJECT_NAME="$(basename "$PROJECT_DIR")"
PROJECT_HASH="$(echo "$PROJECT_DIR" | sha1sum | cut -c1-8)"
SESSION="dev-${PROJECT_NAME}-${PROJECT_HASH}"

mkdir -p "$PROJECT_DIR"
mkdir -p "$CONFIG_DIR"

create_default_config() {
  if [ ! -f "$CONFIG_FILE" ]; then
    cat > "$CONFIG_FILE" <<'CONFIG_EOF'
shell:shell:on
opencode:opencode:on
claude:claude:on
codex:codex:on
CONFIG_EOF
  fi
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

attach_or_switch() {
  if [ -n "$TMUX" ]; then
    tmux switch-client -t "$SESSION"
  else
    tmux attach -t "$SESSION"
  fi
}

create_windows() {
  local first_window_created="false"

  tmux set-option -g base-index 1 >/dev/null 2>&1 || true
  tmux set-window-option -g pane-base-index 1 >/dev/null 2>&1 || true
  tmux set-option -g renumber-windows on >/dev/null 2>&1 || true

  while IFS=":" read -r window_name window_command enabled; do
    if [ -z "$window_name" ] || [ -z "$window_command" ] || [ -z "$enabled" ]; then
      continue
    fi

    if [ "$enabled" != "on" ]; then
      continue
    fi

    if [ "$window_command" != "shell" ] && ! command_exists "$window_command"; then
      continue
    fi

    if [ "$first_window_created" = "false" ]; then
      tmux new-session -d -s "$SESSION" -c "$PROJECT_DIR" -n "$window_name"
      first_window_created="true"

      if [ "$window_command" != "shell" ]; then
        tmux send-keys -t "$SESSION:$window_name" "$window_command" C-m
      fi

      continue
    fi

    tmux new-window -t "$SESSION" -c "$PROJECT_DIR" -n "$window_name"

    if [ "$window_command" != "shell" ]; then
      tmux send-keys -t "$SESSION:$window_name" "$window_command" C-m
    fi
  done < "$CONFIG_FILE"

  if [ "$first_window_created" = "false" ]; then
    tmux new-session -d -s "$SESSION" -c "$PROJECT_DIR" -n shell
  fi
}

start_dev() {
  create_default_config

  if tmux has-session -t "$SESSION" 2>/dev/null; then
    attach_or_switch
    exit 0
  fi

  create_windows
  tmux select-window -t "$SESSION:1"
  attach_or_switch
}

stop_dev() {
  if tmux has-session -t "$SESSION" 2>/dev/null; then
    tmux kill-session -t "$SESSION"
    echo "stopped: $SESSION"
  else
    echo "not running: $SESSION"
  fi
}

kill_dev() {
  TARGET="$2"

  if [ -z "$TARGET" ]; then
    echo "Usage: dev kill <session-name>"
    exit 1
  fi

  if tmux has-session -t "$TARGET" 2>/dev/null; then
    tmux kill-session -t "$TARGET"
    echo "killed: $TARGET"
  else
    echo "not found: $TARGET"
  fi
}

status_dev() {
  if tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "running: $SESSION"
    echo "path: $PROJECT_DIR"
    tmux list-windows -t "$SESSION"
  else
    echo "not running: $SESSION"
    echo "path: $PROJECT_DIR"
  fi
}

list_dev() {
  tmux list-sessions 2>/dev/null | grep '^dev-' || echo "no dev sessions"
}

show_config_table() {
  local index=1

  printf "  %-4s %-16s %-24s %-8s\n" "#" "name" "command" "status"
  printf "  %-4s %-16s %-24s %-8s\n" "----" "----------------" "------------------------" "--------"

  while IFS=":" read -r window_name window_command enabled; do
    if [ -z "$window_name" ] || [ -z "$window_command" ] || [ -z "$enabled" ]; then
      continue
    fi

    printf "  %-4s %-16s %-24s %-8s\n" "$index" "$window_name" "$window_command" "$enabled"
    index=$((index + 1))
  done < "$CONFIG_FILE"
}

select_config_line() {
  local selected

  selected="$(
    awk -F: 'NF == 3 { printf "%s:%s:%s\n", $1, $2, $3 }' "$CONFIG_FILE" |
    gum choose --height 10 --header "Select window"
  )"

  echo "$selected"
}

toggle_window() {
  local selected
  local window_name
  local window_command
  local enabled
  local new_status

  selected="$(select_config_line)"

  if [ -z "$selected" ]; then
    return 0
  fi

  window_name="$(echo "$selected" | cut -d: -f1)"
  window_command="$(echo "$selected" | cut -d: -f2)"
  enabled="$(echo "$selected" | cut -d: -f3)"

  if [ "$enabled" = "on" ]; then
    new_status="off"
  else
    new_status="on"
  fi

  sed -i "s|^$window_name:$window_command:$enabled$|$window_name:$window_command:$new_status|" "$CONFIG_FILE"
}

add_window() {
  local window_name
  local window_command
  local enabled

  window_name="$(gum input --placeholder "window name, example: lazygit")"

  if [ -z "$window_name" ]; then
    return 0
  fi

  window_command="$(gum input --placeholder "run command, example: lazygit")"

  if [ -z "$window_command" ]; then
    return 0
  fi

  enabled="$(gum choose "on" "off" --header "Initial status")"

  if [ -z "$enabled" ]; then
    enabled="on"
  fi

  echo "$window_name:$window_command:$enabled" >> "$CONFIG_FILE"
}

edit_window_command() {
  local selected
  local window_name
  local old_command
  local enabled
  local new_command

  selected="$(select_config_line)"

  if [ -z "$selected" ]; then
    return 0
  fi

  window_name="$(echo "$selected" | cut -d: -f1)"
  old_command="$(echo "$selected" | cut -d: -f2)"
  enabled="$(echo "$selected" | cut -d: -f3)"

  new_command="$(gum input --value "$old_command" --placeholder "run command")"

  if [ -z "$new_command" ]; then
    return 0
  fi

  sed -i "s|^$window_name:$old_command:$enabled$|$window_name:$new_command:$enabled|" "$CONFIG_FILE"
}

delete_window() {
  local selected
  local window_name
  local window_command
  local enabled

  selected="$(select_config_line)"

  if [ -z "$selected" ]; then
    return 0
  fi

  window_name="$(echo "$selected" | cut -d: -f1)"
  window_command="$(echo "$selected" | cut -d: -f2)"
  enabled="$(echo "$selected" | cut -d: -f3)"

  if gum confirm "Delete $window_name?"; then
    sed -i "\|^$window_name:$window_command:$enabled$|d" "$CONFIG_FILE"
  fi
}

move_window() {
  local direction="$1"
  local selected
  local line_number

  selected="$(select_config_line)"

  if [ -z "$selected" ]; then
    return 0
  fi

  line_number="$(grep -n -F "$selected" "$CONFIG_FILE" | head -n1 | cut -d: -f1)"

  if [ -z "$line_number" ]; then
    return 0
  fi

  python3 - "$CONFIG_FILE" "$line_number" "$direction" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
index = int(sys.argv[2]) - 1
direction = sys.argv[3]

lines = path.read_text().splitlines()

if direction == "up" and index > 0:
    lines[index - 1], lines[index] = lines[index], lines[index - 1]

if direction == "down" and index < len(lines) - 1:
    lines[index + 1], lines[index] = lines[index], lines[index + 1]

path.write_text("\n".join(lines) + "\n")
PY
}

open_raw_config() {
  "${EDITOR:-nano}" "$CONFIG_FILE"
}

interactive_config() {
  create_default_config

  if ! command_exists gum; then
    echo "$CONFIG_FILE"
    cat "$CONFIG_FILE"
    return 0
  fi

  while true; do
    clear 2>/dev/null || true

    gum style \
      --foreground 212 \
      --border-foreground 57 \
      --border double \
      --align center \
      --width 64 \
      --margin "1 0" \
      --padding "1 3" \
      "devctl config" \
      "$CONFIG_FILE"

    echo
    show_config_table
    echo

    action="$(gum choose \
      --height 12 \
      --header "Choose action" \
      "Toggle window on/off" \
      "Add window" \
      "Edit window command" \
      "Delete window" \
      "Move window up" \
      "Move window down" \
      "Open raw config" \
      "Exit")"

    case "$action" in
      "Toggle window on/off")
        toggle_window
        ;;
      "Add window")
        add_window
        ;;
      "Edit window command")
        edit_window_command
        ;;
      "Delete window")
        delete_window
        ;;
      "Move window up")
        move_window up
        ;;
      "Move window down")
        move_window down
        ;;
      "Open raw config")
        open_raw_config
        ;;
      "Exit"|"")
        break
        ;;
    esac
  done
}

case "$COMMAND" in
  start)
    start_dev
    ;;
  stop)
    stop_dev
    ;;
  kill)
    kill_dev "$@"
    ;;
  restart)
    stop_dev
    start_dev
    ;;
  status)
    status_dev
    ;;
  list)
    list_dev
    ;;
  config)
    DEVCTL_CONFIG_FILE="$CONFIG_FILE" "$(dirname "$0")/dev-config"
    ;;
  *)
    echo "Usage: dev [start|stop|restart|status|list|kill|config] [path|session-name]"
    exit 1
    ;;
esac
